/data

# Local environment (contains private keys)
.env.local

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


#skills
.agents

# Claude Code — track project commands, ignore cache/sessions
.claude/cache/
.claude/sessions/
.claude/.claude.json
.claude/*.log

# Foundry build artifacts and cache
samelo-contracts/out/
samelo-contracts/cache/
samelo-contracts/broadcast/

